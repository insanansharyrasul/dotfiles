#!/usr/bin/env bash
bat=/sys/class/power_supply/BAT0
per=$(cat "$bat/capacity" 2>/dev/null || echo 0)
status=$(cat "$bat/status" 2>/dev/null || echo Unknown)

icon() {
  if [ "$status" = "Charging" ] || [ "$status" = "Full" ]; then
    echo "σΑ²³"; return
  fi
  icons=(σΑ²é σΑ¹Κ σΑ¹Μ σΑ¹Φ σΑ¹Ϋ σΑ¹Ψ σΑ¹Ω σΑ²Ä σΑ²¹ σΑ²² σΑ¹Ι)
  idx=$(( per / 10 ))
  [ "$idx" -gt 10 ] && idx=10
  echo "${icons[$idx]}"
}

case "$1" in
  icon)    icon ;;
  percent) echo "$per" ;;
  status)  echo "$status" ;;
esac
