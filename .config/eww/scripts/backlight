#!/usr/bin/env bash
level() { brightnessctl -m 2>/dev/null | awk -F, '{print $4}' | tr -d '%'; }
update_eww() {
  command -v eww >/dev/null 2>&1 || return 0
  eww update brightness="$(level)"
}
listen() {
  echo "$(level)"
  if command -v inotifywait >/dev/null 2>&1; then
    device=$(brightnessctl -m 2>/dev/null | awk -F, 'NR==1{print $1}')
    path="/sys/class/backlight/${device}/brightness"
    if [ -n "${device:-}" ] && [ -e "$path" ]; then
      inotifywait -m -e modify "$path" 2>/dev/null | while read -r _; do
        echo "$(level)"
      done
      return 0
    fi
  fi
  while sleep 1; do
    echo "$(level)"
  done
}

case "$1" in
  get) level ;;
  set) v=$(printf '%.0f' "${2:-0}"); brightnessctl set "${v}%" >/dev/null; update_eww ;;
  scroll)
    case "$2" in
      up)   brightnessctl set 5%+ >/dev/null ;;
      down) brightnessctl set 5%- >/dev/null ;;
    esac
    update_eww
    ;;
  listen) listen ;;
esac
