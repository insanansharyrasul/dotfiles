#!/usr/bin/env bash
SRC="@DEFAULT_AUDIO_SOURCE@"

case "$1" in
  icon)
    if wpctl get-volume "$SRC" 2>/dev/null | grep -q MUTED; then echo "󰍭"; else echo "󰍬"; fi ;;
  get)  wpctl get-volume "$SRC" 2>/dev/null | awk '{print int($2 * 100)}' ;;
  set)  v=$(printf '%.0f' "${2:-0}"); wpctl set-volume "$SRC" "${v}%" ;;
  mute) wpctl set-mute "$SRC" toggle ;;
  scroll)
    case "$2" in
      up)   wpctl set-volume "$SRC" 5%+ ;;
      down) wpctl set-volume "$SRC" 5%- ;;
    esac ;;
esac
