#!/usr/bin/env bash
SRC="@DEFAULT_AUDIO_SOURCE@"

level() { wpctl get-volume "$SRC" 2>/dev/null | awk '{print int($2 * 100)}'; }
muted() { wpctl get-volume "$SRC" 2>/dev/null | grep -q MUTED; }
icon() {
  if muted; then echo "󰍭"; else echo "󰍬"; fi
}
payload() {
  printf '{"level":%s,"icon":"%s"}' "$(level)" "$(icon)"
}
emit() {
  printf '%s\n' "$(payload)"
}
update_eww() {
  command -v eww >/dev/null 2>&1 || return 0
  eww update "micState=$(payload)"
}

listen() {
  emit
  if command -v pactl >/dev/null 2>&1; then
    pactl subscribe 2>/dev/null | while read -r line; do
      case "$line" in
        *"source"*|*"server"*)
          emit
          ;;
      esac
    done
  else
    while sleep 1; do
      emit
    done
  fi
}

case "$1" in
  icon) icon ;;
  get)  level ;;
  set)  v=$(printf '%.0f' "${2:-0}"); wpctl set-volume "$SRC" "${v}%"; update_eww ;;
  mute) wpctl set-mute "$SRC" toggle; update_eww ;;
  scroll)
    case "$2" in
      up)   wpctl set-volume "$SRC" 5%+ ;;
      down) wpctl set-volume "$SRC" 5%- ;;
    esac
    update_eww
    ;;
  listen) listen ;;
esac
